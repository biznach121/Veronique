{
  "name": "thespabox2",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "concurrently -k -n mock,next -c blue,magenta \"cimplify-mock --seed services --quiet\" \"next dev\"",
    "dev:storefront": "next dev",
    "dev:mock": "cimplify-mock --seed services",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "check:brand": "vitest run __tests__/brand.test.ts",
    "check:cart": "vitest run __tests__/cart-flow.test.ts",
    "check:contract": "vitest run __tests__/contract.test.ts",
    "check": "bun run typecheck && bun run test:run"
  },
  "dependencies": {
    "@cimplify/sdk": "^0.88.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
