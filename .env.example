# Your tenant public key. Get it from the desk's Developers tab.
# `cpk_live_*` / `cpk_test_*` keys auto-route same-origin requests
# to hosted Cimplify in both dev and prod. Anything else (`mock-dev`,
# empty) falls back to the local `cimplify dev` mock.
NEXT_PUBLIC_CIMPLIFY_PUBLIC_KEY=mock-dev

# Optional. Force the storefront SDK and Next rewrites to hit a specific
# Cimplify API. Set these to hosted Cimplify when developing against live data.
# CIMPLIFY_API_URL=https://storefronts.cimplify.io
# NEXT_PUBLIC_CIMPLIFY_API_URL=https://storefronts.cimplify.io

# Optional. Forces a fixed canonical URL for sitemap.xml, robots.txt,
# OpenGraph, and llms.txt. Leave unset and the storefront derives the
# canonical from the request `Host` header automatically.
# NEXT_PUBLIC_SITE_URL=
